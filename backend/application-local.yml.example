# 本地密钥配置（此文件已被 gitignore，不会提交到仓库）
# 复制为 application-local.yml 并填入真实值

zdsj:
  wechat:
    appid: YOUR_WX_APPID
    secret: YOUR_WX_APP_SECRET
    # subscribe-template-id: YOUR_SUBSCRIBE_TEMPLATE_ID  # 可选，降价提醒订阅消息
  affiliate:
    mock: false
    provider:
      jd:
        primary: veapi
        fallback: jd_official,mock
      pdd:
        primary: veapi
        fallback: mock
    veapi:
      vekey: YOUR_VEAPI_VEKEY
      secret: YOUR_VEAPI_SECRET   # 可选，与会员中心一致时填写
      jd:
        auth-mode: self
        union-id: YOUR_JD_UNION_ID      # 维易 jd_prombyuid 必填，与京东联盟媒体 ID 一致
        position-id: YOUR_JD_POSITION_ID  # 推广位，建议配置以便跟单
        scene-id: 2                       # 单品转链：item.jd.com/数字SKU（需联盟 sceneId=2 权限）
        chain-type: 1                     # 1=长链 clickURL，2=短链 u.jd.com
      pdd:
        auth-mode: self
        pid: YOUR_PDD_PID
    jd:
      app-key: YOUR_JD_APP_KEY
      app-secret: YOUR_JD_APP_SECRET
      union-id: YOUR_JD_UNION_ID
      # site-id: YOUR_JD_SITE_ID      # 可选，有站点 ID 时用 common 转链
      # position-id: YOUR_JD_PID      # 可选，推广位
    pdd:
      client-id: YOUR_PDD_CLIENT_ID
      client-secret: YOUR_PDD_CLIENT_SECRET
      pid: YOUR_PDD_PID               # 推广位，格式如 123456_789012345
  ai:
    mock: false
    base-url: https://api.deepseek.com/v1
    api-key: YOUR_DEEPSEEK_API_KEY
    model-high: deepseek-v4-pro
    model-fast: deepseek-v4-flash
