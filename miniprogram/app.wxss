/* 全局样式 */
page {
  background-color: #f5f6f8;
  color: #1f2329;
  font-size: 28rpx;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

.container {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #1f2329;
}

.muted {
  color: #8a9099;
  font-size: 24rpx;
}

.price {
  color: #fa3534;
  font-weight: 700;
}

.price-big {
  color: #fa3534;
  font-weight: 700;
  font-size: 52rpx;
}

.btn-primary {
  background: #1a73e8;
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.btn-ghost {
  background: #eef3fe;
  color: #1a73e8;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.row {
  display: flex;
  align-items: center;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.disclaimer {
  color: #b0b4ba;
  font-size: 22rpx;
  line-height: 1.6;
  margin-top: 12rpx;
}

.empty {
  text-align: center;
  color: #b0b4ba;
  padding: 80rpx 0;
  font-size: 26rpx;
}
