{
  "pages": [
    "pages/search/search",
    "pages/rank/rank",
    "pages/watch/watch",
    "pages/mine/mine"
  ],
  "subPackages": [
    {
      "root": "packageA",
      "name": "packageA",
      "pages": [
        "pages/analysis/analysis",
        "pages/settings/settings",
        "pages/data-notice/data-notice",
        "pages/privacy/privacy",
        "pages/webview/webview",
        "pages/copy-link/copy-link"
      ]
    }
  ],
  "preloadRule": {
    "pages/search/search": {
      "network": "all",
      "packages": ["packageA"]
    }
  },
  "window": {
    "backgroundTextStyle": "dark",
    "navigationBarBackgroundColor": "#ffffff",
    "navigationBarTitleText": "真到手价",
    "navigationBarTextStyle": "black",
    "backgroundColor": "#f5f6f8"
  },
  "tabBar": {
    "color": "#9aa0a6",
    "selectedColor": "#1a73e8",
    "backgroundColor": "#ffffff",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/search/search",
        "text": "查价",
        "iconPath": "assets/tabbar/search.png",
        "selectedIconPath": "assets/tabbar/search_active.png"
      },
      {
        "pagePath": "pages/rank/rank",
        "text": "低价榜",
        "iconPath": "assets/tabbar/rank.png",
        "selectedIconPath": "assets/tabbar/rank_active.png"
      },
      {
        "pagePath": "pages/watch/watch",
        "text": "盯价",
        "iconPath": "assets/tabbar/watch.png",
        "selectedIconPath": "assets/tabbar/watch_active.png"
      },
      {
        "pagePath": "pages/mine/mine",
        "text": "我的",
        "iconPath": "assets/tabbar/mine.png",
        "selectedIconPath": "assets/tabbar/mine_active.png"
      }
    ]
  },
  "usingComponents": {
    "privacy-popup": "/components/privacy-popup/privacy-popup"
  },
  "__usePrivacyCheck__": true,
  "permission": {
    "scope.userFuzzyLocation": {
      "desc": "用于推荐你所在地区的国补政策"
    }
  },
  "lazyCodeLoading": "requiredComponents",
  "style": "v2",
  "sitemapLocation": "sitemap.json"
}
