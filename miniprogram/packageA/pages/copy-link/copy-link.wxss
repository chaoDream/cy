.page {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
}
.title {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}
.hint {
  font-size: 24rpx;
  color: #8a9099;
  line-height: 1.6;
  display: block;
  margin-bottom: 24rpx;
}
.link-box {
  background: #f5f6f8;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  word-break: break-all;
}
.link-text {
  font-size: 26rpx;
  color: #1a73e8;
  line-height: 1.5;
}
.copy-btn {
  width: 100%;
  margin-bottom: 24rpx;
}
.tip {
  font-size: 22rpx;
  color: #b0b4ba;
  line-height: 1.6;
  display: block;
  text-align: center;
}
