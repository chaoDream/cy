.card-title { font-size: 30rpx; font-weight: 600; margin-bottom: 16rpx; }
.type-list { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 20rpx; }
.type-chip {
  padding: 12rpx 28rpx;
  background: #f2f3f5;
  color: #6b7280;
  border-radius: 999rpx;
  font-size: 26rpx;
}
.type-chip.on { background: #1a73e8; color: #fff; }
.fb-content {
  width: 100%;
  min-height: 200rpx;
  background: #f7f8fa;
  border-radius: 14rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  margin-bottom: 24rpx;
}
.tip { display: block; margin-top: 16rpx; padding: 0 8rpx; line-height: 1.6; }
.muted { color: #8a9099; font-size: 24rpx; }
.notice .p {
  display: block;
  color: #4b5563;
  font-size: 26rpx;
  line-height: 1.8;
  margin-bottom: 12rpx;
}
