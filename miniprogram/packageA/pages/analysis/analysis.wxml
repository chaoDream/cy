<view wx:if="{{loading}}" class="loading">正在为你算真实到手价…</view>

<view wx:elif="{{error}}" class="error-box">
  <text>{{error}}</text>
  <button class="btn-ghost" bindtap="_load">重试</button>
</view>

<view wx:else class="page-wrap">
<scroll-view scroll-y class="page-scroll">
  <!-- 1. 商品基础信息 -->
  <view class="card prod">
    <image wx:if="{{data.productInfo.imageUrl}}" class="prod-img" src="{{data.productInfo.imageUrl}}" mode="aspectFill" />
    <view wx:else class="prod-img prod-img-empty">暂无图片</view>
    <view class="prod-info">
      <text class="prod-title">{{data.productInfo.title}}</text>
      <view class="prod-meta">
        <text class="tag">{{platformText}}</text>
        <text class="tag" wx:if="{{shopTypeText}}">{{shopTypeText}}</text>
        <text class="tag {{item.gov ? 'tag-gov' : ''}}" wx:for="{{productTags}}" wx:key="text">{{item.text}}</text>
      </view>
      <text class="prod-shop muted">{{data.productInfo.shopName}}</text>
      <view class="sku-conf">
        标准型号：{{data.skuInfo.standardName}}
        <text class="conf conf-{{data.skuInfo.confidence}}">置信度{{data.skuInfo.confidence}}</text>
      </view>
      <view wx:if="{{data.skuInfo.needConfirm}}" class="need-confirm">疑似同款，需谨慎比较</view>
    </view>
  </view>

  <!-- 2. AI 购买结论（独立加载，不阻塞首屏） -->
  <view class="card-plain">
    <ai-conclusion
      loading="{{aiLoading}}"
      rec="{{aiRecommendation}}"
      error="{{aiError}}"
      bind:retry="onRetryAi"
    />
  </view>

  <!-- 3. 当前参考到手价 -->
  <view class="card price-card">
    <text class="card-title">当前参考到手价</text>
    <view class="price-row">
      <text class="price-big" wx:if="{{!data.priceInfo.pricePending}}">¥{{data.priceInfo.finalPriceText}}</text>
      <text class="price-big muted" wx:else>待获取</text>
      <text class="price-origin" wx:if="{{!data.priceInfo.pricePending}}">展示价 ¥{{data.priceInfo.displayPriceText}}</text>
      <text class="price-origin muted" wx:else>联盟暂未返回价格，请重新粘贴链接或稍后重试</text>
    </view>
  </view>

  <!-- 4. 价格脱水路径（瀑布流） -->
  <view class="card-plain">
    <price-waterfall price="{{data.priceInfo}}" bind:expand="onPriceExpand" />
  </view>

  <!-- 5. 风险提示 -->
  <view class="card" bindtap="onRiskView">
    <text class="card-title">风险提示</text>
    <risk-tag tags="{{data.riskInfo}}" />
  </view>

  <!-- 6. 历史价格 -->
  <view class="card-plain">
    <price-trend trend="{{data.trendInfo}}" current="{{data.priceInfo.estimatedFinalPrice}}" />
  </view>

  <!-- 7. 更优选择（差异化 / 跨平台） -->
  <view class="card" wx:if="{{crossView.length}}">
    <text class="card-title">更优选择（差异化 / 跨平台）</text>
    <view wx:if="{{!sameItemBuyable}}" class="cross-hint muted">
      这款直接购买可能无返利，以下为更划算的同型号或跨平台选择
    </view>
    <view class="cross-item" wx:for="{{crossView}}" wx:key="itemId">
      <view class="cross-left">
        <text class="tag">{{item.platformText}}</text>
        <text class="muted">{{item.shopTypeText}}</text>
      </view>
      <text class="price">¥{{item.price}}</text>
      <button
        wx:if="{{item.cpsLink}}"
        class="btn-ghost cross-buy"
        size="mini"
        data-idx="{{index}}"
        bindtap="onBuyCross"
      >去购买</button>
    </view>
  </view>

  <!-- 合规说明 -->
  <view class="compliance">
    <text>{{data.priceInfo.disclaimer}}</text>
    <navigator url="/packageA/pages/data-notice/data-notice" class="link">数据来源与免责说明 ›</navigator>
  </view>

  <view class="bottom-space"></view>
</scroll-view>

<!-- 8. 操作区（与 scroll-view 同级，避免 100vh 滚动层挡住按钮点击） -->
<view class="action-bar">
  <view class="action-sub" bindtap="onFeedback">反馈错误</view>
  <button class="btn-ghost action-watch" bindtap="onWatch">盯价</button>
  <button
    class="btn-primary action-buy"
    bindtap="onBuy"
  >{{sameItemBuyable ? '去购买' : '看更优选择'}}</button>
</view>
<!-- 盯价弹窗 -->
<view wx:if="{{watchModal.show}}" class="wm-mask" bindtap="onCloseWatchModal">
  <view class="wm-panel" catchtap="noop">
    <view class="wm-header">
      <text class="wm-title">设置盯价</text>
      <text class="wm-close" catchtap="onCloseWatchModal">✕</text>
    </view>

    <view class="wm-current">
      <text class="wm-current-label">当前价格</text>
      <text class="wm-current-price">¥{{watchModal.currentPriceText}}</text>
    </view>

    <view class="wm-opts">
      <view
        wx:for="{{watchModal.options}}"
        wx:key="pct"
        class="wm-opt {{watchModal.selectedPct === item.pct ? 'active' : ''}}"
        data-pct="{{item.pct}}"
        catchtap="onPickPct"
      >
        <text class="wm-opt-pct">降价{{item.pct}}%</text>
        <text class="wm-opt-price">¥{{item.priceText}}</text>
      </view>
    </view>

    <input
      class="wm-input {{watchModal.inputError ? 'error' : ''}}"
      type="digit"
      value="{{watchModal.customPrice}}"
      focus="{{watchModal.inputFocus}}"
      placeholder="请输入您想要的价格"
      placeholder-class="wm-input-ph"
      bindfocus="onCustomFocus"
      bindinput="onCustomInput"
    />
    <text class="wm-hint {{watchModal.inputError ? 'error' : ''}}">
      {{watchModal.inputError ? '当前价格就是你想要的价格，直接去购买吧' : '如果达到价格我们将会给您发送提示信息，请注意查收'}}
    </text>

    <view class="wm-scope">
      <text class="wm-scope-label">盯价范围</text>
      <view class="wm-scope-opts">
        <view
          class="wm-scope-opt {{watchModal.scope === 'merchant' ? 'active' : ''}}"
          data-scope="merchant"
          catchtap="onPickScope"
        >只盯当前商家这个价</view>
        <view
          class="wm-scope-opt {{watchModal.scope === 'platform_lowest' ? 'active' : ''}}"
          data-scope="platform_lowest"
          catchtap="onPickScope"
        >盯全平台同款最低价</view>
      </view>
    </view>

    <button class="wm-submit" disabled="{{!watchModal.canSubmit}}" catchtap="onConfirmWatch">开始盯价</button>
  </view>
</view>

<!-- 国补定位弹窗 -->
<view wx:if="{{locModal.show}}" class="loc-mask">
  <view class="loc-panel" catchtap="noop">
    <view class="loc-icon">📍</view>
    <text class="loc-title">开启定位享受国补优惠</text>
    <text class="loc-desc">该商品支持国家补贴，开启位置信息后可自动计算您所在地区的国补金额</text>
    <button class="loc-btn loc-btn-allow" catchtap="onLocAllow">允许获取位置</button>
    <button class="loc-btn loc-btn-deny" catchtap="onLocDeny">拒绝</button>
    <text class="loc-manual" catchtap="onLocManual">暂不开启，手动选择地区</text>
  </view>
</view>

<!-- 手动选择地区弹窗 -->
<view wx:if="{{regionPicker.show}}" class="loc-mask" bindtap="onCloseRegionPicker">
  <view class="rp-panel" catchtap="noop">
    <view class="rp-header">
      <text class="rp-title">选择国补地区</text>
      <text class="rp-close" catchtap="onCloseRegionPicker">✕</text>
    </view>
    <picker-view class="rp-picker" value="{{[regionIndex]}}" bindchange="onRegionChange">
      <picker-view-column>
        <view wx:for="{{provinces}}" wx:key="*this" class="rp-item">{{item}}</view>
      </picker-view-column>
    </picker-view>
    <button class="rp-confirm" catchtap="onRegionConfirm">确认选择</button>
  </view>
</view>

<privacy-popup></privacy-popup>
</view>
