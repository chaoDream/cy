.page-wrap {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}
.page-scroll {
  flex: 1;
  height: 0;
  padding: 24rpx;
  box-sizing: border-box;
}
.loading, .error-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  color: #8a9099;
  gap: 24rpx;
}
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}
.card-plain { margin-bottom: 24rpx; }
.card-title { font-size: 30rpx; font-weight: 600; margin-bottom: 16rpx; display: block; }
.muted { color: #8a9099; font-size: 24rpx; }
.price { color: #fa3534; font-weight: 700; }
.price-big { color: #fa3534; font-weight: 700; font-size: 56rpx; }

.prod { display: flex; }
.prod-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 14rpx;
  background: #f2f3f5;
  flex-shrink: 0;
}
.prod-img-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #8a9099;
}
.prod-info { flex: 1; margin-left: 20rpx; }
.prod-title {
  font-size: 28rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.prod-meta { display: flex; gap: 12rpx; margin: 10rpx 0; }
.tag {
  background: #eef3fe;
  color: #1a73e8;
  font-size: 22rpx;
  padding: 2rpx 14rpx;
  border-radius: 6rpx;
}
.tag-gov {
  background: #fdecec;
  color: #e23b3b;
  font-weight: 600;
}
.prod-shop { display: block; }
.sku-conf { font-size: 22rpx; color: #6b7280; margin-top: 10rpx; }
.conf { margin-left: 10rpx; padding: 2rpx 10rpx; border-radius: 6rpx; font-size: 20rpx; }
.conf-high { background: #e8f8ee; color: #34c759; }
.conf-mid { background: #fff7e6; color: #f08c00; }
.conf-low { background: #fff4f0; color: #e8590c; }
.need-confirm { color: #e8590c; font-size: 22rpx; margin-top: 8rpx; }

.price-card .price-row { display: flex; align-items: baseline; gap: 20rpx; }
.price-origin { color: #b0b4ba; font-size: 24rpx; text-decoration: line-through; }

.cross-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 2rpx solid #f2f3f5;
}
.cross-item:last-child { border-bottom: none; }
.cross-left { display: flex; align-items: center; gap: 12rpx; }
.cross-buy { margin: 0 0 0 16rpx; }
.cross-hint {
  font-size: 22rpx;
  line-height: 1.5;
  padding: 8rpx 0 16rpx;
  color: #b0742a;
}

.compliance {
  padding: 0 8rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.compliance text { color: #b0b4ba; font-size: 22rpx; line-height: 1.6; }
.link { color: #1a73e8; font-size: 24rpx; }
.bottom-space { height: 24rpx; }

.action-bar {
  flex-shrink: 0;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.06);
  gap: 20rpx;
  z-index: 10;
}
.action-sub {
  font-size: 22rpx;
  color: #8a9099;
  text-align: center;
  width: 120rpx;
}
.action-watch { flex: 1; }
.action-buy { flex: 1.4; }

/* ============ 盯价弹窗 ============ */
.wm-mask {
  position: fixed;
  left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}
.wm-panel {
  width: 100%;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}
.wm-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.wm-title { font-size: 32rpx; font-weight: 700; color: #1f2329; }
.wm-close { font-size: 32rpx; color: #b0b4ba; padding: 0 10rpx; }

.wm-current {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.wm-current-label { font-size: 26rpx; color: #6b7280; }
.wm-current-price { font-size: 40rpx; font-weight: 700; color: #1f2329; }

/* 三个降价档位 */
.wm-opts { display: flex; gap: 18rpx; margin-bottom: 24rpx; }
.wm-opt {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 18rpx 0;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  background: #fff;
}
.wm-opt.active {
  border-color: #fa3534;
  background: #fff5f5;
}
.wm-opt-pct { font-size: 26rpx; color: #1f2329; }
.wm-opt.active .wm-opt-pct { color: #fa3534; font-weight: 700; }
.wm-opt-price { font-size: 24rpx; color: #8a9099; }
.wm-opt.active .wm-opt-price { color: #fa3534; }

/* 自定义输入 */
.wm-input {
  width: 100%;
  box-sizing: border-box;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #1f2329;
}
.wm-input.error { border-color: #fa3534; }
.wm-input-ph { color: #b0b4ba; }
.wm-hint {
  display: block;
  font-size: 22rpx;
  color: #8a9099;
  margin: 12rpx 4rpx 0;
}
.wm-hint.error { color: #fa3534; }

/* 盯价范围 */
.wm-scope { margin-top: 28rpx; }
.wm-scope-label { font-size: 26rpx; color: #6b7280; }
.wm-scope-opts { display: flex; gap: 18rpx; margin-top: 14rpx; }
.wm-scope-opt {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: #1f2329;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
}
.wm-scope-opt.active {
  border-color: #1a73e8;
  background: #eef4ff;
  color: #1a73e8;
  font-weight: 700;
}

/* 提交 */
.wm-submit {
  margin-top: 32rpx;
  background: #fa3534;
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
}
.wm-submit[disabled] {
  background: #d9dbe0;
  color: #fff;
}

/* ============ 国补定位弹窗 ============ */
.loc-mask {
  position: fixed;
  left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.loc-panel {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.loc-icon { font-size: 72rpx; margin-bottom: 16rpx; }
.loc-title { font-size: 34rpx; font-weight: 700; color: #1f2329; margin-bottom: 12rpx; }
.loc-desc { font-size: 26rpx; color: #6b7280; text-align: center; line-height: 1.6; margin-bottom: 32rpx; }
.loc-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  text-align: center;
  margin-bottom: 16rpx;
}
.loc-btn-allow { background: #fa3534; color: #fff; }
.loc-btn-deny { background: #f2f3f5; color: #6b7280; }
.loc-manual { font-size: 26rpx; color: #1a73e8; margin-top: 8rpx; padding: 8rpx 0; }

/* ============ 手动选择地区弹窗 ============ */
.rp-panel {
  width: 100%;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  position: fixed;
  left: 0; bottom: 0;
  z-index: 1001;
}
.rp-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.rp-title { font-size: 32rpx; font-weight: 700; color: #1f2329; }
.rp-close { font-size: 32rpx; color: #b0b4ba; padding: 0 10rpx; }
.rp-picker { height: 400rpx; width: 100%; }
.rp-item {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #1f2329;
}
.rp-confirm {
  margin-top: 20rpx;
  background: #fa3534;
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
}
