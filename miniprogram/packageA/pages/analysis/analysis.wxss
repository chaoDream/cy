.page-wrap {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}
.page-scroll {
  flex: 1;
  height: 0;
  padding: 24rpx;
  box-sizing: border-box;
}
.loading, .error-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  color: #8a9099;
  gap: 24rpx;
}
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}
.card-plain { margin-bottom: 24rpx; }
.card-title { font-size: 30rpx; font-weight: 600; margin-bottom: 16rpx; display: block; }
.muted { color: #8a9099; font-size: 24rpx; }
.price { color: #fa3534; font-weight: 700; }
.price-big { color: #fa3534; font-weight: 700; font-size: 56rpx; }

/* ============ 商品详情卡片 ============ */
.prod-card { padding: 24rpx; }
.prod-main { display: flex; gap: 20rpx; }
.prod-img-wrap {
  position: relative;
  flex-shrink: 0;
  width: 200rpx;
  height: 200rpx;
}
.prod-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background: #f7f8fa;
}
.prod-img-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #8a9099;
}
.prod-img-badge {
  position: absolute;
  left: 0;
  bottom: 0;
  right: 0;
  padding: 6rpx 12rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 20rpx;
  font-weight: 500;
  text-align: center;
  border-radius: 0 0 16rpx 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.prod-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.prod-title-area {
  position: relative;
}
.prod-title-measure {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  visibility: hidden;
  pointer-events: none;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.45;
}
.prod-title {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.45;
  color: #1f2329;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.prod-title-area-tap .prod-title {
  padding-right: 44rpx;
}
.prod-title-icon {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 52rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0) 0%, #fff 40%);
  pointer-events: none;
}
.prod-title-chevron {
  width: 12rpx;
  height: 12rpx;
  border-right: 3rpx solid #8a9099;
  border-bottom: 3rpx solid #8a9099;
  transform: rotate(45deg);
  margin-top: -6rpx;
}
.prod-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}
.prod-tag {
  font-size: 22rpx;
  color: #1a73e8;
  background: #f0f5ff;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  line-height: 1.4;
}
.prod-tag-gov {
  color: #d4380d;
  background: #fff2e8;
  font-weight: 500;
}
.prod-shop {
  font-size: 24rpx;
  color: #8a9099;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.prod-sku {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 20rpx;
  padding: 16rpx 18rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
}
.prod-sku-label {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #8a9099;
  padding-top: 2rpx;
}
.prod-sku-name {
  flex: 1;
  font-size: 24rpx;
  color: #4e5969;
  line-height: 1.5;
}
.prod-alert {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  background: #fff7e6;
  border-radius: 12rpx;
  border: 1rpx solid #ffe7ba;
}
.prod-alert-icon {
  flex-shrink: 0;
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #d46b08;
  background: #ffd591;
  border-radius: 50%;
}
.prod-alert-text {
  flex: 1;
  font-size: 24rpx;
  color: #d46b08;
  line-height: 1.5;
}

.tag {
  background: #eef3fe;
  color: #1a73e8;
  font-size: 22rpx;
  padding: 2rpx 14rpx;
  border-radius: 6rpx;
}
.tag-gov {
  background: #fdecec;
  color: #e23b3b;
  font-weight: 600;
}

/* ============ 标题全文弹窗 ============ */
.title-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.title-panel {
  width: 620rpx;
  max-height: 70vh;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}
.title-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  flex-shrink: 0;
}
.title-panel-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
}
.title-panel-close {
  font-size: 32rpx;
  color: #b0b4ba;
  padding: 0 8rpx;
}
.title-panel-body {
  flex: 1;
  max-height: 50vh;
}
.title-panel-text {
  font-size: 28rpx;
  color: #4e5969;
  line-height: 1.65;
  word-break: break-all;
}

/* ============ 店铺切换卡片 ============ */
.shop-alt-card { padding: 24rpx 28rpx; }
.sa-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.sa-title { font-size: 28rpx; font-weight: 600; color: #1f2329; }
.sa-hint { font-size: 22rpx; }
.sa-body {
  display: flex;
  align-items: center;
}
.sa-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 0;
  border-radius: 16rpx;
}
.sa-current { background: #f7f8fa; }
.sa-alt { background: #f0f9f4; }
.sa-label {
  font-size: 20rpx;
  color: #8a9099;
  background: #e5e7eb;
  padding: 2rpx 16rpx;
  border-radius: 20rpx;
}
.sa-label-alt { background: #d4f0dd; color: #1a9d49; }
.sa-type { font-size: 26rpx; font-weight: 600; color: #1f2329; }
.sa-shop {
  font-size: 22rpx;
  color: #8a9099;
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.sa-price { font-size: 36rpx; font-weight: 700; color: #fa3534; margin-top: 4rpx; }
.sa-price-pending { font-size: 28rpx; color: #b0b4ba; font-weight: 400; }
.sa-price-alt { color: #1a9d49; }
.sa-arrow-wrap {
  width: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.sa-arrow { font-size: 36rpx; color: #b0b4ba; }
.sa-action {
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
}
.sa-btn {
  width: 100%;
  text-align: center;
  padding: 18rpx 0;
  background: #1a9d49;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 44rpx;
}
.price-card .price-row { display: flex; align-items: baseline; gap: 20rpx; }
.price-origin { color: #b0b4ba; font-size: 24rpx; text-decoration: line-through; }

.cross-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 2rpx solid #f2f3f5;
}
.cross-item:last-child { border-bottom: none; }
.cross-left { display: flex; align-items: center; gap: 12rpx; }
.cross-buy { margin: 0 0 0 16rpx; }
.cross-hint {
  font-size: 22rpx;
  line-height: 1.5;
  padding: 8rpx 0 16rpx;
  color: #b0742a;
}

.compliance {
  padding: 0 8rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.compliance text { color: #b0b4ba; font-size: 22rpx; line-height: 1.6; }
.link { color: #1a73e8; font-size: 24rpx; }
.bottom-space { height: 24rpx; }

.action-bar {
  flex-shrink: 0;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.06);
  gap: 20rpx;
  z-index: 10;
}
.action-sub {
  font-size: 22rpx;
  color: #8a9099;
  text-align: center;
  width: 120rpx;
}
.action-watch { flex: 1; }
.action-buy { flex: 1.4; }

/* ============ 盯价弹窗 ============ */
.wm-mask {
  position: fixed;
  left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}
.wm-panel {
  width: 100%;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}
.wm-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.wm-title { font-size: 32rpx; font-weight: 700; color: #1f2329; }
.wm-close { font-size: 32rpx; color: #b0b4ba; padding: 0 10rpx; }

.wm-current {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.wm-current-label { font-size: 26rpx; color: #6b7280; }
.wm-current-price { font-size: 40rpx; font-weight: 700; color: #1f2329; }

/* 三个降价档位 */
.wm-opts { display: flex; gap: 18rpx; margin-bottom: 24rpx; }
.wm-opt {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 18rpx 0;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  background: #fff;
}
.wm-opt.active {
  border-color: #fa3534;
  background: #fff5f5;
}
.wm-opt-pct { font-size: 26rpx; color: #1f2329; }
.wm-opt.active .wm-opt-pct { color: #fa3534; font-weight: 700; }
.wm-opt-price { font-size: 24rpx; color: #8a9099; }
.wm-opt.active .wm-opt-price { color: #fa3534; }

/* 自定义输入 */
.wm-input {
  width: 100%;
  box-sizing: border-box;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #1f2329;
}
.wm-input.error { border-color: #fa3534; }
.wm-input-ph { color: #b0b4ba; }
.wm-hint {
  display: block;
  font-size: 22rpx;
  color: #8a9099;
  margin: 12rpx 4rpx 0;
}
.wm-hint.error { color: #fa3534; }

/* 盯价范围 */
.wm-scope { margin-top: 28rpx; }
.wm-scope-label { font-size: 26rpx; color: #6b7280; }
.wm-scope-opts { display: flex; gap: 18rpx; margin-top: 14rpx; }
.wm-scope-opt {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: #1f2329;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
}
.wm-scope-opt.active {
  border-color: #1a73e8;
  background: #eef4ff;
  color: #1a73e8;
  font-weight: 700;
}

/* 提交 */
.wm-submit {
  margin-top: 32rpx;
  background: #fa3534;
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
}
.wm-submit[disabled] {
  background: #d9dbe0;
  color: #fff;
}

/* ============ 国补定位弹窗 ============ */
.loc-mask {
  position: fixed;
  left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.loc-panel {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.loc-icon { font-size: 72rpx; margin-bottom: 16rpx; }
.loc-title { font-size: 34rpx; font-weight: 700; color: #1f2329; margin-bottom: 12rpx; }
.loc-desc { font-size: 26rpx; color: #6b7280; text-align: center; line-height: 1.6; margin-bottom: 32rpx; }
.loc-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  text-align: center;
  margin-bottom: 16rpx;
}
.loc-btn-allow { background: #fa3534; color: #fff; }
.loc-btn-deny { background: #f2f3f5; color: #6b7280; }
.loc-manual { font-size: 26rpx; color: #1a73e8; margin-top: 8rpx; padding: 8rpx 0; }

/* ============ 手动选择地区弹窗 ============ */
.rp-panel {
  width: 100%;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  position: fixed;
  left: 0; bottom: 0;
  z-index: 1001;
}
.rp-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.rp-title { font-size: 32rpx; font-weight: 700; color: #1f2329; }
.rp-close { font-size: 32rpx; color: #b0b4ba; padding: 0 10rpx; }
.rp-picker { height: 400rpx; width: 100%; }
.rp-item {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #1f2329;
}
.rp-confirm {
  margin-top: 20rpx;
  background: #fa3534;
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
}
