.clip-hint {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff7e6;
  border: 2rpx solid #ffe0a3;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}
.clip-text { color: #b76e00; font-size: 26rpx; }
.clip-actions { display: flex; align-items: center; gap: 20rpx; }
.clip-btn { color: #1a73e8; font-size: 26rpx; font-weight: 600; }
.clip-close { color: #b0b4ba; font-size: 36rpx; }

.link-input {
  width: 100%;
  min-height: 140rpx;
  background: #f7f8fa;
  border-radius: 14rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}
.parse-btn {
  margin-top: 20rpx;
}
.search-line {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  background: #f7f8fa;
  border-radius: 999rpx;
  padding: 0 24rpx;
}
.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 26rpx;
}
.search-go {
  color: #1a73e8;
  font-size: 26rpx;
  padding-left: 16rpx;
}
.section { margin-top: 24rpx; }
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
}
.section-more {
  font-size: 24rpx;
  color: #1a73e8;
  padding: 8rpx 0;
}
.recent-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  max-height: 120rpx;
  overflow: hidden;
}
.recent-chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #fff;
  border: 1rpx solid #e8e9eb;
  border-radius: 999rpx;
  padding: 8rpx 20rpx 8rpx 8rpx;
  flex-shrink: 0;
}
.recent-chip-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}
.recent-chip-dot-jd { background: linear-gradient(135deg, #e1251b, #ff6b57); }
.recent-chip-dot-pdd { background: linear-gradient(135deg, #e02e24, #ff8a65); }
.recent-chip-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #202124;
  white-space: nowrap;
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 好价推荐 */
.recommend-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.recommend-item {
  width: calc((100% - 16rpx) / 2);
  box-sizing: border-box;
  background: #fff;
  border-radius: 16rpx;
  padding: 12rpx;
}
.recommend-img {
  width: 100%;
  height: 240rpx;
  border-radius: 12rpx;
  background: #f2f3f5;
}
.recommend-img-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #b0b4ba;
  font-size: 22rpx;
}
.recommend-title {
  font-size: 24rpx;
  line-height: 1.4;
  margin-top: 10rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.recommend-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}
.recommend-price {
  color: #fa3534;
  font-weight: 700;
  font-size: 32rpx;
}
.recommend-platform {
  font-size: 20rpx;
  color: #1a73e8;
  background: #eef3fe;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}
.recommend-footer {
  text-align: center;
  color: #b0b4ba;
  font-size: 24rpx;
  padding: 24rpx 0 16rpx;
}

/* 最近查询弹窗（列表行样式） */
.recent-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
}
.recent-thumb {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
  background: #f2f3f5;
  flex-shrink: 0;
}
.recent-thumb-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}
.recent-thumb-jd { background: linear-gradient(135deg, #e1251b, #ff6b57); }
.recent-thumb-pdd { background: linear-gradient(135deg, #e02e24, #ff8a65); }
.recent-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.recent-model {
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 500;
  color: #202124;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.recent-platform {
  font-size: 22rpx;
  color: #8a9099;
}

/* 最近查询弹窗 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}
.popup-content {
  width: 100%;
  max-height: 70vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
}
.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f1f3;
  flex-shrink: 0;
}
.popup-title {
  font-size: 32rpx;
  font-weight: 600;
}
.popup-close {
  font-size: 44rpx;
  color: #8a9099;
  line-height: 1;
  padding: 0 8rpx;
}
.popup-scroll {
  flex: 1;
  min-height: 0;
}
.popup-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 24rpx;
}
.popup-row {
  background: #f7f8fa;
}
.popup-loading,
.popup-end {
  text-align: center;
  color: #b0b4ba;
  font-size: 24rpx;
  padding: 24rpx 0;
}
