<view class="container">
  <view class="profile card">
    <view class="profile-info-row">
      <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" binderror="onAvatarError" />
      <view wx:else class="avatar-img avatar-default">
        <text class="avatar-default-icon">👤</text>
      </view>
      <view class="profile-info">
        <text class="name">{{loading ? '登录中…' : (nickname || '省心用户')}}</text>
        <text class="muted">站在用户这边的 AI 购物决策助手</text>
      </view>
    </view>
  </view>

  <view class="block-title">省钱资产库</view>
  <asset-library assets="{{assets}}" bind:change="onAssetsChange" />

  <view class="menu card">
    <view class="menu-item" bindtap="goSettings">
      <text>提醒设置</text><text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goDataNotice">
      <text>数据来源与免责说明</text><text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goFeedback">
      <text>纠错反馈</text><text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goPrivacy">
      <text>隐私政策与用户协议</text><text class="arrow">›</text>
    </view>
  </view>

  <view class="cps-note">
    本产品通过京东联盟 / 多多进宝官方渠道获取返佣，返佣不影响推荐排序，且仅使用官方公开接口数据。
  </view>
</view>
