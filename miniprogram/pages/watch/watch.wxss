.login-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
  padding: 120rpx 40rpx;
}
.login-box button { width: 80%; }
.empty { text-align: center; color: #b0b4ba; padding: 100rpx 0; }
.muted { color: #8a9099; font-size: 26rpx; }
.price { color: #fa3534; font-weight: 700; }
.target { color: #1a73e8; font-weight: 700; }

/* 全局降价提醒开关 */
.notify-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.nb-text { display: flex; flex-direction: column; gap: 6rpx; }
.nb-title { font-size: 30rpx; font-weight: 700; color: #1f2329; }
.nb-sub { font-size: 22rpx; color: #8a9099; }

.watch-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.wc-top { display: flex; }
.wc-img {
  width: 150rpx;
  height: 150rpx;
  border-radius: 14rpx;
  background: #f2f3f5;
  flex-shrink: 0;
}
.wc-info { flex: 1; margin-left: 20rpx; display: flex; flex-direction: column; }
.wc-title {
  font-size: 28rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.wc-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: auto;
  padding-top: 12rpx;
}
.wc-status { font-size: 22rpx; line-height: 1; display: inline-flex; align-items: center; }
.wc-mode {
  font-size: 20rpx;
  line-height: 1;
  color: #8a9099;
  background: #f2f3f5;
  border-radius: 6rpx;
  padding: 6rpx 12rpx;
  display: inline-flex;
  align-items: center;
}
.status-watching { color: #34c759; }
.status-hit { color: #fa3534; }
.status-paused { color: #b0b4ba; }

/* 三档价格：原价 / 当前到手价 / 目标价，等宽对齐 */
.wc-prices {
  display: flex;
  margin-top: 20rpx;
  padding: 18rpx 0;
  background: #fafbfc;
  border-radius: 14rpx;
}
.pc {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.pc + .pc { border-left: 2rpx solid #eef0f3; }
.pc-label { font-size: 22rpx; color: #8a9099; }
.pc-val { font-size: 30rpx; font-weight: 700; }
.pc-val.origin { color: #b0b4ba; text-decoration: line-through; font-weight: 400; }
.pc-val.now { color: #fa3534; }
.pc-val.target { color: #1a73e8; }

.wc-hit-tip { display: block; font-size: 22rpx; color: #fa3534; margin-top: 12rpx; }

.wc-actions {
  display: flex;
  justify-content: flex-end;
  gap: 30rpx;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 2rpx solid #f2f3f5;
}
.wc-act { color: #1a73e8; font-size: 26rpx; }
.wc-act.danger { color: #fa3534; }
