<view class="container">
  <view wx:if="{{loading}}" class="empty">加载中…</view>

  <view wx:elif="{{loadError}}" class="empty">{{loadError}}</view>

  <view wx:elif="{{!list.length}}" class="empty">还没有盯价商品，去查价页加一个吧</view>

  <block wx:else>
    <view class="notify-bar">
      <view class="nb-text">
        <text class="nb-title">降价提醒</text>
        <text class="nb-sub">关闭后，所有盯价都不再推送提醒</text>
      </view>
      <switch checked="{{notifyAll}}" color="#34c759" bindchange="onToggleNotifyAll" />
    </view>

    <view class="watch-card" wx:for="{{list}}" wx:key="watchId">
      <view
        class="wc-top"
        data-platform="{{item.platform}}"
        data-itemid="{{item.platformItemId}}"
        bindtap="onTapItem"
      >
        <image class="wc-img" src="{{item.imageUrl}}" mode="aspectFill" />
        <view class="wc-info">
          <text class="wc-title">{{item.title}}</text>
          <view class="wc-meta">
            <text class="wc-status status-{{item.status}}">{{item.status === 'hit' ? '已达目标价' : (item.status === 'paused' ? '已暂停' : '盯价中')}}</text>
            <text class="wc-mode">{{item.watchMode === 'platform_lowest' ? '全平台同款最低价' : '当前商家'}}</text>
          </view>
        </view>
      </view>

      <view class="wc-prices">
        <view class="pc">
          <text class="pc-label">原价</text>
          <text class="pc-val origin">{{item.originalPriceText === '--' ? '--' : '¥' + item.originalPriceText}}</text>
        </view>
        <view class="pc">
          <text class="pc-label">当前到手价</text>
          <text class="pc-val now">{{item.currentPriceText === '--' ? '--' : '¥' + item.currentPriceText}}</text>
        </view>
        <view class="pc">
          <text class="pc-label">目标价</text>
          <text class="pc-val target">{{item.targetPriceText === '--' ? '--' : '¥' + item.targetPriceText}}</text>
        </view>
      </view>

      <text wx:if="{{item.status === 'hit'}}" class="wc-hit-tip">已达目标价，请重新订阅以继续提醒</text>
      <view class="wc-actions">
        <text class="wc-act" data-watchid="{{item.watchId}}" data-current="{{item.targetPrice}}" bindtap="onEditTarget">改目标价</text>
        <text class="wc-act" data-index="{{index}}" data-watchid="{{item.watchId}}" data-mode="{{item.watchMode}}" bindtap="onSwitchMode">切换范围</text>
        <text class="wc-act danger" data-watchid="{{item.watchId}}" bindtap="onRemove">删除盯价</text>
      </view>
    </view>
  </block>
</view>
