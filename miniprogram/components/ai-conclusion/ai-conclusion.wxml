<view wx:if="{{loading}}" class="ai-skeleton">
  <view class="ai-skel-head">
    <view class="ai-skel-line ai-skel-title"></view>
    <view class="ai-skel-line ai-skel-conf"></view>
  </view>
  <view class="ai-skel-line ai-skel-reason"></view>
  <view class="ai-skel-line ai-skel-reason short"></view>
  <text class="ai-skel-hint">AI 正在分析购买建议…</text>
</view>

<view wx:elif="{{error}}" class="ai-error">
  <text class="ai-error-text">{{error}}</text>
  <text class="ai-error-retry" bindtap="onRetry">点击重试</text>
</view>

<view wx:elif="{{rec}}" class="ai-card {{themeMap[rec.conclusion]}}">
  <view class="ai-head">
    <text class="ai-label">{{rec.conclusionLabel}}</text>
    <text class="ai-conf">AI 置信度 {{rec.confidence}}</text>
  </view>
  <view class="ai-reasons">
    <view class="ai-reason" wx:for="{{rec.reasons}}" wx:key="index">
      <text class="dot">·</text><text>{{item}}</text>
    </view>
  </view>
  <view class="ai-risk" wx:if="{{rec.riskHint}}">{{rec.riskHint}}</view>
  <view class="ai-foot">AI 仅基于公开价格事实给出解释，不代表投资/购买承诺</view>
</view>
