.ai-card {
  border-radius: 20rpx;
  padding: 28rpx;
  color: #fff;
}
.ai-card.buy { background: linear-gradient(135deg, #34c759, #28a745); }
.ai-card.wait { background: linear-gradient(135deg, #ff9f0a, #f08c00); }
.ai-card.caution { background: linear-gradient(135deg, #ff6b35, #e8590c); }
.ai-card.avoid { background: linear-gradient(135deg, #ff453a, #d32f2f); }

.ai-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}
.ai-label {
  font-size: 40rpx;
  font-weight: 700;
}
.ai-conf {
  font-size: 24rpx;
  opacity: 0.9;
}
.ai-reasons {
  margin-top: 18rpx;
}
.ai-reason {
  display: flex;
  font-size: 26rpx;
  line-height: 1.7;
  opacity: 0.96;
}
.ai-reason .dot {
  margin-right: 10rpx;
}
.ai-risk {
  margin-top: 16rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 24rpx;
  line-height: 1.6;
}
.ai-foot {
  margin-top: 16rpx;
  font-size: 20rpx;
  opacity: 0.8;
}
