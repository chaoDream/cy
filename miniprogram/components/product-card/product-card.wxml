<view class="pc" bindtap="onTap">
  <image wx:if="{{item.imageUrl}}" class="pc-img" src="{{item.imageUrl}}" mode="aspectFill" lazy-load />
  <view wx:else class="pc-img pc-img-empty">无图</view>
  <view class="pc-body">
    <text class="pc-title">{{item.title || item.standardName}}</text>
    <view class="pc-meta">
      <text class="pc-platform">{{platformText}}</text>
      <text class="pc-shop" wx:if="{{item.shopName}}">{{item.shopName}}</text>
    </view>
    <view class="pc-tags" wx:if="{{item.riskTags.length}}">
      <text class="pc-risk" wx:for="{{item.riskTags}}" wx:key="*this">{{item}}</text>
    </view>
    <view class="pc-price">
      <text class="muted">参考到手价</text>
      <text class="price-big">{{priceText === '--' ? '--' : '¥' + priceText}}</text>
    </view>
  </view>
</view>
