<view wx:if="{{visible}}" class="pp-mask" catchtouchmove="noop">
  <view class="pp-card">
    <view class="pp-title">是否同意隐私协议</view>
    <view class="pp-body">
      <text class="pp-text">只有同意隐私协议才能有自动复制购买链接。</text>
    </view>
    <view class="pp-actions">
      <button class="pp-btn pp-btn-ghost" bindtap="onDisagree">不同意</button>
      <button
        class="pp-btn pp-btn-primary"
        open-type="agreePrivacyAuthorization"
        bindagreeprivacyauthorization="onAgree"
      >同意</button>
    </view>
  </view>
</view>
