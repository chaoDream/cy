.pp-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pp-card {
  width: 80%;
  max-width: 620rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 32rpx;
  box-sizing: border-box;
}

.pp-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24rpx;
  color: #1f1f1f;
}

.pp-body {
  font-size: 28rpx;
  line-height: 1.6;
  color: #555;
  margin-bottom: 40rpx;
}

.pp-link {
  color: #1a73e8;
}

.pp-actions {
  display: flex;
  gap: 24rpx;
}

.pp-btn {
  flex: 1;
  margin: 0;
  font-size: 30rpx;
  border-radius: 999rpx;
  line-height: 2.6;
}

.pp-btn-ghost {
  background: #f2f3f5;
  color: #666;
}

.pp-btn-primary {
  background: #1a73e8;
  color: #fff;
}

.pp-btn::after {
  border: none;
}
