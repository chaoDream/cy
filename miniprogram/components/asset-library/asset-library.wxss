.asset-lib {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
}
.al-title {
  display: flex;
  flex-direction: column;
  margin-bottom: 18rpx;
}
.al-title text:first-child {
  font-size: 30rpx;
  font-weight: 600;
}
.al-sub {
  color: #8a9099;
  font-size: 22rpx;
  margin-top: 6rpx;
}
.al-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.al-tag {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: #f2f3f5;
  color: #6b7280;
  font-size: 26rpx;
  border: 2rpx solid transparent;
}
.al-tag.on {
  background: #eef3fe;
  color: #1a73e8;
  border-color: #1a73e8;
}
