# 本地一键部署配置（复制为 deploy.local.env 后填入，勿提交 Git）
# cp deploy.local.env.example deploy.local.env

# 服务器 SSH 地址（公网 IP 或域名）
DEPLOY_HOST=62.234.81.122

# SSH 用户名（腾讯云 CVM 常见：ubuntu / root）
DEPLOY_USER=ubuntu

# 服务器上仓库根目录（含 backend/、deploy/ 的那一层）
DEPLOY_PATH=/home/ubuntu/shengxin-buy

# 要部署的分支
DEPLOY_BRANCH=main

# 可选：SSH 私钥路径（默认使用 ssh-agent / ~/.ssh/config）
# DEPLOY_SSH_KEY=~/.ssh/id_rsa

# 可选：Git remote 名
# GIT_REMOTE=origin

# 可选：部署完成后健康检查 URL（默认 http://${DEPLOY_HOST}/api/health）
# HEALTH_URL=http://62.234.81.122/api/health
