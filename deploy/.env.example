# 复制为 .env 后填入真实值：cp .env.example .env

# ---------- 数据库（PostgreSQL 容器） ----------
POSTGRES_DB=zdsj
POSTGRES_USER=zdsj
POSTGRES_PASSWORD=请替换为强密码

# ---------- 安全 ----------
# 至少 32 字节随机串
JWT_SECRET=请替换为至少32字节的随机字符串

# ---------- 微信小程序 ----------
WX_APPID=wx_your_appid
WX_SECRET=your_app_secret
WX_SUB_TEMPLATE=your_subscribe_template_id

# ---------- 联盟 API（生产关闭 mock） ----------
AFFILIATE_MOCK=false
PDD_CLIENT_ID=
PDD_CLIENT_SECRET=
PDD_PID=
JD_APP_KEY=
JD_APP_SECRET=
JD_UNION_ID=
JD_SITE_ID=
JD_POSITION_ID=

# ---------- 大模型（DeepSeek） ----------
AI_MOCK=false
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=
AI_MODEL_HIGH=deepseek-v4-flash
AI_MODEL_FAST=deepseek-v4-flash

# ---------- Nginx ----------
# 首次部署（无 SSL）：保持默认
NGINX_CONF=./nginx/default.http-only.conf
# 证书就绪后（deploy/certs/fullchain.pem + privkey.pem）改为：
# NGINX_CONF=./nginx/default.conf
